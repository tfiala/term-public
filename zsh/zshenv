# term-public zshenv.
#
# The primary terminfo fix is in setup.sh, which installs xterm-ghostty
# into ~/.terminfo so zsh finds it at startup.  This fallback handles
# the case where setup.sh was not run (e.g. SSH from Ghostty to a host
# that only has term-public checked out, not bootstrapped).
#
# NOTE: zsh may still print "can't find terminal definition" before this
# file runs — the warning is cosmetic when the fallback sets TERM below.
if (( $+commands[infocmp] )) && ! infocmp "$TERM" &>/dev/null; then
  if [[ "$TERM" == *ghostty* \
      && -d /Applications/Ghostty.app/Contents/Resources/terminfo ]]; then
    export TERMINFO=/Applications/Ghostty.app/Contents/Resources/terminfo
  else
    export TERM=xterm-256color
  fi
fi

# Source the user's prior .zshenv if setup.sh backed it up.
if [[ -f "$HOME/.zshenv.bak" ]]; then
  source "$HOME/.zshenv.bak"
fi
